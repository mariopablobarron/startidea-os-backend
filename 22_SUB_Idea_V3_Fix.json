{
  "name": "SUB_Idea_V3_Fix",
  "nodes": [
    { "parameters": {}, "id": "trig_i3f", "name": "Execute Workflow Trigger", "type": "n8n-nodes-base.executeWorkflowTrigger", "position": [0,0] },
    {
      "parameters": {
        "keepOnlySet": true,
        "values": {
          "string": [
            { "name": "prompt_sistema", "value": "Eres el OS Startidea. Estructura el input del usuario OBLIGATORIAMENTE en este JSON exacto: {\\\"titulo\\\": \\\"...\\\", \\\"descripcion\\\": \\\"...\\\", \\\"categoria\\\": \\\"...\\\", \\\"accion_sugerida\\\": \\\"...\\\", \\\"prioridad\\\": \\\"alta|media|baja\\\", \\\"tipo_tarea\\\": \\\"estrategica|operativa\\\"}." },
            { "name": "texto_usuario", "value": "={{ $json.message.text.replace(/^\\/idea\\s*/, '') }}" },
            { "name": "user_id", "value": "={{ $json.message.from.id }}" },
            { "name": "chat_id", "value": "={{ $json.message.chat.id }}" }
          ]
        }
      },
      "id": "set_i3f", "name": "Set_Contexto", "type": "n8n-nodes-base.set", "position": [200,0]
    },
    { "parameters": { "workflowId": "SELECCIONE_SYS_LLM_CORE_V3_FIX" }, "id": "call_llm3f", "name": "Llamar_LLM_Core", "type": "n8n-nodes-base.executeWorkflow", "position": [400,0] },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO core.ideas (user_id, raw_input, titulo, descripcion, categoria, accion_sugerida, prioridad_sugerida, tipo_tarea_sugerida) VALUES ($1, $2, $3, $4, $5, $6, $7, $8) RETURNING id;",
        "options": { "queryParameters": "={{ $('Set_Contexto').item.json.user_id }}, {{ $('Set_Contexto').item.json.texto_usuario }}, {{ $json.payload.titulo }}, {{ $json.payload.descripcion }}, {{ $json.payload.categoria }}, {{ $json.payload.accion_sugerida }}, {{ $json.payload.prioridad }}, {{ $json.payload.tipo_tarea }}" }
      },
      "id": "db_i3f", "name": "Insert_BD_Idea", "type": "n8n-nodes-base.postgres", "position": [600,0]
    },
    {
      "parameters": {
        "chatId": "={{ $('Set_Contexto').item.json.chat_id }}",
        "text": "=💡 **{{ $('Llamar_LLM_Core').item.json.payload.titulo }}**\\n📌 Acción: {{ $('Llamar_LLM_Core').item.json.payload.accion_sugerida }}\\n🔥 Prioridad: `{{ $('Llamar_LLM_Core').item.json.payload.prioridad }}`",
        "replyMarkup": "inlineKeyboard",
        "inlineKeyboard": { "rows": [ { "row": { "buttons": [ { "text": "Validar y Crear Tarea 🎯", "callback_data": "=validar_idea:{{ $json[0].id }}" } ] } } ] }
      },
      "id": "tg_i3f", "name": "Telegram_Boton", "type": "n8n-nodes-base.telegram", "position": [800,0]
    }
  ],
  "connections": {
    "Execute Workflow Trigger": { "main": [ [ { "node": "Set_Contexto", "type": "main", "index": 0 } ] ] },
    "Set_Contexto": { "main": [ [ { "node": "Llamar_LLM_Core", "type": "main", "index": 0 } ] ] },
    "Llamar_LLM_Core": { "main": [ [ { "node": "Insert_BD_Idea", "type": "main", "index": 0 } ] ] },
    "Insert_BD_Idea": { "main": [ [ { "node": "Telegram_Boton", "type": "main", "index": 0 } ] ] }
  }
}
