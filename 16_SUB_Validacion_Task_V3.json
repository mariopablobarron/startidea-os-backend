{
  "name": "SUB_Validacion_Task_V3",
  "nodes": [
    { "parameters": {}, "id": "trig_v3", "name": "Execute Workflow Trigger", "type": "n8n-nodes-base.executeWorkflowTrigger", "position": [0,0] },
    {
      "parameters": { "operation": "answerCallbackQuery", "queryId": "={{ $json.callback_query.id }}", "text": "Procesando transferencia a Task..." },
      "id": "ans_v3", "name": "Responder_Callback", "type": "n8n-nodes-base.telegram", "position": [200,0]
    },
    {
      "parameters": {
        "keepOnlySet": true,
        "values": {
          "string": [
            { "name": "idea_id", "value": "={{ $('Execute Workflow Trigger').item.json.callback_query.data.split(':')[1] }}" },
            { "name": "chat_id", "value": "={{ $('Execute Workflow Trigger').item.json.callback_query.message.chat.id }}" }
          ]
        }
      },
      "id": "set_v3", "name": "Set_Ids", "type": "n8n-nodes-base.set", "position": [400,0]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "UPDATE core.ideas SET estado = 'validada' WHERE id = $1 AND estado = 'capturada' RETURNING accion_sugerida, prioridad_sugerida, tipo_tarea_sugerida;",
        "options": { "queryParameters": "={{ $('Set_Ids').item.json.idea_id }}" }
      },
      "id": "db_up3", "name": "Postgres_Actualizar_Idea", "type": "n8n-nodes-base.postgres", "position": [600,0]
    },
    {
      "parameters": { "conditions": { "string": [ { "value1": "={{ $json[0]?.accion_sugerida }}", "operation": "isNotEmpty" } ] } },
      "id": "if_v3", "name": "If_Idea_Validada", "type": "n8n-nodes-base.if", "position": [800,0]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO core.tasks (idea_id, titulo, prioridad, tipo_tarea) VALUES ($1, $2, $3, $4) RETURNING id;",
        "options": { "queryParameters": "={{ $('Set_Ids').item.json.idea_id }}, {{ $('Postgres_Actualizar_Idea').item.json[0].accion_sugerida }}, {{ $('Postgres_Actualizar_Idea').item.json[0].prioridad_sugerida }}, {{ $('Postgres_Actualizar_Idea').item.json[0].tipo_tarea_sugerida }}" }
      },
      "id": "db_ins3", "name": "Postgres_Insertar_Task", "type": "n8n-nodes-base.postgres", "position": [1000,-100]
    },
    {
      "parameters": {
        "operation": "editMessageReplyMarkup",
        "chatId": "={{ $('Set_Ids').item.json.chat_id }}",
        "messageId": "={{ $('Execute Workflow Trigger').item.json.callback_query.message.message_id }}",
        "replyMarkup": "inlineKeyboard",
        "inlineKeyboard": { "rows": [] }
      },
      "id": "rem_btn3", "name": "Remover_Boton_Idea", "type": "n8n-nodes-base.telegram", "position": [1200,-100]
    },
    {
      "parameters": {
        "chatId": "={{ $('Set_Ids').item.json.chat_id }}",
        "text": "=🚀 **Conversión a Tarea Éxitosa (#{{ $('Postgres_Insertar_Task').item.json[0].id }})**\\n*\"{{ $('Postgres_Actualizar_Idea').item.json[0].accion_sugerida }}\"*\\n🔥 Prioridad Heredada: `{{ $('Postgres_Actualizar_Idea').item.json[0].prioridad_sugerida }}`",
        "replyMarkup": "inlineKeyboard",
        "inlineKeyboard": { "rows": [ { "row": { "buttons": [ { "text": "✅ Done", "callback_data": "=done_task:{{ $('Postgres_Insertar_Task').item.json[0].id }}" }, { "text": "🔄 Posponer", "callback_data": "=postpone_task:{{ $('Postgres_Insertar_Task').item.json[0].id }}" } ] } } ] }
      },
      "id": "tg_conf3", "name": "Telegram_Send_Confirmacion", "type": "n8n-nodes-base.telegram", "position": [1400,-100]
    }
  ],
  "connections": {
    "Execute Workflow Trigger": { "main": [ [ { "node": "Responder_Callback", "type": "main", "index": 0 } ] ] },
    "Responder_Callback": { "main": [ [ { "node": "Set_Ids", "type": "main", "index": 0 } ] ] },
    "Set_Ids": { "main": [ [ { "node": "Postgres_Actualizar_Idea", "type": "main", "index": 0 } ] ] },
    "Postgres_Actualizar_Idea": { "main": [ [ { "node": "If_Idea_Validada", "type": "main", "index": 0 } ] ] },
    "If_Idea_Validada": { "main": [ [ { "node": "Postgres_Insertar_Task", "type": "main", "index": 0 } ] ] },
    "Postgres_Insertar_Task": { "main": [ [ { "node": "Remover_Boton_Idea", "type": "main", "index": 0 } ] ] },
    "Remover_Boton_Idea": { "main": [ [ { "node": "Telegram_Send_Confirmacion", "type": "main", "index": 0 } ] ] }
  }
}
